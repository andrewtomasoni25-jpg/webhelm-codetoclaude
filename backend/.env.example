# Copy this file to .env and fill in your own values.
# All fields are OPTIONAL — the backend runs without any of them and will
# append form submissions to backend/submissions.log as JSONL.

# ---- MongoDB (optional — only if you want submissions persisted to a DB) ----
# MONGO_URL=mongodb://localhost:27017
# DB_NAME=webhelm

# ---- Resend (optional — only if you want the form to email you) ----
# Get a free key at https://resend.com (3,000 emails/month free tier).
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
# SENDER_EMAIL=noreply@webhelm.co
# RECIPIENT_EMAIL=contact@webhelm.co

# ---- CORS (optional — defaults to * for local dev) ----
# CORS_ORIGINS=https://webhelm.co,https://www.webhelm.co
